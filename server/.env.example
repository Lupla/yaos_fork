# Shared secret token for authenticating websocket connections.
# Set this to a random string. All plugin clients must use the same value.
SYNC_TOKEN=change-me-to-a-random-secret

# R2 blob storage for attachment sync (optional — only needed if clients enable attachment sync).
# Create an R2 API token at: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# The token needs "Object Read & Write" permissions on the target bucket.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-api-token-access-key
R2_SECRET_ACCESS_KEY=your-r2-api-token-secret
R2_BUCKET_NAME=vault-crdt-sync
